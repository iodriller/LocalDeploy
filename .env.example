OLLAMA_BASE_URL=http://127.0.0.1:11434
LLAMACPP_BASE_URL=http://127.0.0.1:8080
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
DOCKER_MODEL_RUNNER_BASE_URL=http://127.0.0.1:12434
# VLLM_BASE_URL=http://127.0.0.1:8001
# OPENAI_COMPAT_BASE_URL=http://127.0.0.1:8001
LLAMACPP_SERVER_PATH=
LLAMACPP_STARTUP_TIMEOUT_SECONDS=180
REQUIRE_GPU_ONLY=false
DEFAULT_BACKEND=ollama
# Pin a specific profile as the default for /chat and the CLIs. Leave unset to
# use config.json's default_profile, which is set automatically on first pull.
# DEFAULT_MODEL_PROFILE=
CONFIG_PATH=config.json
API_HOST=127.0.0.1
API_PORT=8000
REQUEST_TIMEOUT_SECONDS=180
SLOW_RESPONSE_SECONDS=60
# Seconds to wait for a model to warm into memory on Start/Switch. Default scales
# with the device (longer for CPU offload, which is slow for large models). Set
# this to override both paths with a fixed value.
# OLLAMA_LOAD_TIMEOUT=600
GLOBAL_MAX_PROMPT_CHARS=20000
GLOBAL_MAX_OUTPUT_TOKENS=2048
GLOBAL_MAX_IMAGES=8
GLOBAL_MAX_IMAGE_MB=10
ENABLE_LLAMA_CPP=false
ENABLE_CORS=false
ENABLE_WEB_UI=true
# OFFLINE=true blocks all outbound internet calls (Hugging Face update checks
# are skipped). Local backend calls to loopback are unaffected. Verify with:
#   python scripts/egress_selftest.py
OFFLINE=false
# Optional local shared token. This is not internet-facing authentication: there
# is no TLS, per-user identity, tenant isolation, or rate limiting. When set, the
# HTTP API requires the token via the 'X-API-Token' header, 'Authorization:
# Bearer <token>', or '?token=<token>'. Open the UI once at /ui?token=<token>.
API_TOKEN=
# A non-loopback API_HOST always prints a startup warning, even with a token.
# This legacy switch hard-fails only when a non-loopback bind also has no token.
REQUIRE_TOKEN_ON_LAN=false
